{
  "name": "kura",
  "version": "0.1.0",
  "description": "Local knowledge management CLI backed by SQLite with hybrid RAG search",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run src/cli/index.ts",
    "build:client": "bun run scripts/build-html.ts",
    "build": "bun run build:client",
    "compile": "bun run build && bun build src/cli/index.ts --compile --outfile=kura",
    "test": "bun test",
    "check": "bunx tsc --noEmit && bunx @biomejs/biome check src"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.17.0",
    "@mozilla/readability": "^0.6.0",
    "linkedom": "^0.18.11",
    "sqlite-vec": "^0.1.7-alpha.2",
    "turndown": "^7.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.0",
    "@types/bun": "^1.3.0",
    "@types/d3-force": "^3.0.10",
    "@types/markdown-it": "^14.1.2",
    "@types/turndown": "^5.0.5",
    "d3-force": "^3.0.0",
    "dompurify": "^3.2.6",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.0",
    "preact": "^10.26.9",
    "typescript": "^5.8.0",
    "wouter": "^3.7.1",
    "wouter-preact": "^3.10.0"
  }
}
